        // Render catalog grid dan opsi dropdown formulir secara dinamis
        function renderJaringanKost() {
            const container = document.getElementById('cabang-grid-container');
            const dropdown = document.getElementById('branch');
            const heroList = document.getElementById('hero-branches-list');
            
            if (!container || !dropdown || !heroList) return;

            // Reset Konten
            container.innerHTML = '';
            heroList.innerHTML = '';
            dropdown.innerHTML = '<option value="" disabled selected>Pilih Cabang Kos</option>';

            // Loop 1 - 7 Cabang
            for (let i = 1; i <= 7; i++) {
                const cab = cabangData[i];
                if (!cab) continue;

                // 1. Render Catalog Cards
                let badgeClass = 'bg-green-500/10 text-green-600';
                let dotClass = 'bg-green-500';
                if (cab.statusColor === 'amber') {
                    badgeClass = 'bg-amber-500/10 text-amber-600';
                    dotClass = 'bg-amber-500';
                } else if (cab.statusColor === 'red') {
                    badgeClass = 'bg-red-500/10 text-red-600';
                    dotClass = 'bg-red-500';
                }

                // Compile tag html
                let tagsHtml = '';
                cab.tags.forEach(tag => {
                    tagsHtml += `<span class="text-[9px] bg-slate-100 text-slate-600 px-2 py-0.5 rounded-md font-medium">${tag}</span>`;
                });

                const cardHtml = `
                    <div class="bg-white border border-slate-100 rounded-3xl p-5 shadow-sm hover:shadow-xl transition-all duration-300 flex flex-col justify-between">
                        <div class="space-y-4">
                            <div class="flex justify-between items-start">
                                <span class="bg-brand-100 text-brand-700 text-[10px] font-extrabold uppercase px-2.5 py-1 rounded-lg">${cab.tagArea}</span>
                                <span class="${badgeClass} text-[10px] font-bold px-2 py-0.5 rounded-full flex items-center">
                                    <span class="w-1.5 h-1.5 rounded-full ${dotClass} mr-1"></span>${cab.status}
                                </span>
                            </div>
                            <div>
                                <h3 class="font-extrabold text-slate-900 text-base md:text-lg">${cab.nama}</h3>
                                <p class="text-slate-500 text-xs mt-1 leading-relaxed"><i class="fa-solid fa-map-pin mr-1 text-slate-400"></i> ${cab.alamat}</p>
                            </div>
                            <div class="pt-3 border-t border-slate-100 flex justify-between items-center text-xs">
                                <span class="text-slate-500">Harga Mulai</span>
                                <span class="font-extrabold text-brand-600 text-sm">Rp ${cab.harga} <span class="text-[9px] font-medium text-slate-400">/bln</span></span>
                            </div>
                            <div class="flex flex-wrap gap-1.5 pt-1">
                                ${tagsHtml}
                            </div>
                        </div>
                        <div class="grid grid-cols-2 gap-2 mt-6">
                            <button onclick="switchLocation(${cab.id})" class="bg-slate-100 hover:bg-slate-200 text-slate-700 text-xs font-bold py-2 px-3 rounded-xl transition-all flex items-center justify-center space-x-1">
                                <i class="fa-solid fa-map-location-dot"></i>
                                <span>Peta</span>
                            </button>
                            <a href="#survey-form" onclick="selectCabangForm('${cab.nama}')" class="bg-brand-600 hover:bg-brand-700 text-white text-xs font-bold py-2 px-3 rounded-xl transition-all text-center">
                                ${cab.status === 'Penuh' ? 'Waiting List' : 'Survey'}
                            </a>
                        </div>
                    </div>
                `;
                container.insertAdjacentHTML('beforeend', cardHtml);

                // 2. Render Hero Side Preview (3 Cabang Pertama saja)
                if (i <= 3) {
                    let heroBadgeHtml = `<span class="text-[10px] bg-green-500/20 text-green-400 font-bold px-2 py-0.5 rounded">Tersedia</span>`;
                    if (cab.statusColor === 'amber') {
                        heroBadgeHtml = `<span class="text-[10px] bg-amber-500/20 text-amber-400 font-bold px-2 py-0.5 rounded">${cab.status}</span>`;
                    } else if (cab.statusColor === 'red') {
                        heroBadgeHtml = `<span class="text-[10px] bg-red-500/20 text-red-400 font-bold px-2 py-0.5 rounded">Penuh</span>`;
                    }

                    const heroItemHtml = `
                        <div class="flex items-center justify-between p-2.5 bg-slate-950/40 border border-slate-800/60 rounded-xl">
                            <div class="flex items-center space-x-2.5">
                                <div class="bg-brand-500/20 text-brand-400 w-8 h-8 rounded-lg flex items-center justify-center text-xs font-bold">${cab.id}</div>
                                <span class="text-xs font-extrabold text-slate-100">${cab.nama}</span>
                            </div>
                            ${heroBadgeHtml}
                        </div>
                    `;
                    heroList.insertAdjacentHTML('beforeend', heroItemHtml);
                }

                // 3. Render Form Dropdown Options
                const optionHtml = `<option value="${cab.nama}">Cabang ${cab.id}: ${cab.nama}</option>`;
                dropdown.insertAdjacentHTML('beforeend', optionHtml);
            }
        }

        // Muat Data Cabang yang dipilih oleh Owner ke dalam Input Form Owner Panel
        function loadCabangToForm() {
            const selectId = document.getElementById('owner-edit-cabang-select').value;
            const cab = cabangData[selectId];
            if (!cab) return;

            document.getElementById('edit-cab-nama').value = cab.nama;
            document.getElementById('edit-cab-tag').value = cab.tagArea;
            document.getElementById('edit-cab-alamat').value = cab.alamat;
            document.getElementById('edit-cab-harga').value = cab.harga;
            document.getElementById('edit-cab-status').value = cab.status;
            document.getElementById('edit-cab-status-color').value = cab.statusColor;
            document.getElementById('edit-cab-tags-list').value = cab.tags.join(', ');
            document.getElementById('edit-cab-maps-embed').value = cab.mapsEmbed;
            document.getElementById('edit-cab-maps-link').value = cab.mapsLink;

            // Muat 4 akses terdekat
            for (let i = 1; i <= 4; i++) {
                const aksesObj = cab.akses[i - 1] || { tempat: '', jarak: '' };
                document.getElementById(`edit-cab-akses-t${i}`).value = aksesObj.tempat;
                document.getElementById(`edit-cab-akses-j${i}`).value = aksesObj.jarak;
            }
        }

        // Perbarui data cabang di database sementara/memori
        function updateCabangData() {
            const selectId = document.getElementById('owner-edit-cabang-select').value;
            const cab = cabangData[selectId];
            if (!cab) return;

            cab.nama = document.getElementById('edit-cab-nama').value.trim();
            cab.tagArea = document.getElementById('edit-cab-tag').value.trim();
            cab.alamat = document.getElementById('edit-cab-alamat').value.trim();
            cab.harga = document.getElementById('edit-cab-harga').value.trim();
            cab.status = document.getElementById('edit-cab-status').value;
            cab.statusColor = document.getElementById('edit-cab-status-color').value;
            
            // Proses 3 tag fasilitas dari koma
            const rawTags = document.getElementById('edit-cab-tags-list').value;
            cab.tags = rawTags.split(',').map(t => t.trim()).filter(t => t !== '');

            cab.mapsEmbed = document.getElementById('edit-cab-maps-embed').value.trim();
            cab.mapsLink = document.getElementById('edit-cab-maps-link').value.trim();

            // Ambil data 4 akses terdekat
            cab.akses = [];
            for (let i = 1; i <= 4; i++) {
                const tempat = document.getElementById(`edit-cab-akses-t${i}`).value.trim();
                const jarak = document.getElementById(`edit-cab-akses-j${i}`).value.trim();
                if (tempat) {
                    cab.akses.push({ tempat, jarak });
                }
            }

            // Render ulang komponen visual web agar langsung berubah di depan mata!
            renderJaringanKost();
            switchLocation(selectId); // Perbarui peta ke cabang yang baru diedit

            // Beri notifikasi toast keberhasilan
            showToast("Data Cabang Berhasil Diperbarui secara Instan!");
        }

        // Tampilkan pesan popup toast
        function showToast(message) {
            const toast = document.createElement('div');
            toast.className = 'fixed top-4 left-1/2 transform -translate-x-1/2 z-50 bg-green-600 text-white px-6 py-3 rounded-xl shadow-lg font-bold text-xs flex items-center space-x-2 animate-bounce';
            toast.innerHTML = `<i class="fa-solid fa-circle-check"></i> <span>${message}</span>`;
            document.body.appendChild(toast);
            setTimeout(() => toast.remove(), 3000);
        }

        // Switch Maps Location aktif dari katalog cabang
        function switchLocation(id) {
            const data = cabangData[id];
            if (!data) return;

            // Update Iframe Peta
            document.getElementById('google-maps-embed').src = data.mapsEmbed;

            // Update Label Detail Lokasi
            document.getElementById('label-cabang').textContent = data.nama;
            document.getElementById('label-alamat').textContent = data.alamat;
            document.getElementById('btn-directions').href = data.mapsLink;

            // Update List Jarak Akses Terdekat
            const listContainer = document.getElementById('akses-list');
            listContainer.innerHTML = '';
            
            data.akses.forEach(item => {
                const row = document.createElement('div');
                row.className = 'flex items-center justify-between text-xs';
                row.innerHTML = `
                    <span class="text-slate-300"><i class="fa-solid fa-graduation-cap text-brand-400 mr-2"></i> ${item.tempat}</span>
                    <span class="font-bold text-teal-400">${item.jarak}</span>
                `;
                listContainer.appendChild(row);
            });

            // Gulir halaman ke maps secara halus
            document.getElementById('lokasi').scrollIntoView({ behavior: 'smooth' });
        }

        // Autoselect dropdown cabang pada formulir survey
        function selectCabangForm(value) {
            const selectEl = document.getElementById('branch');
            if (selectEl) {
                selectEl.value = value;
            }
        }

        // Switch active tab di dalam Owner Panel
        function switchOwnerTab(tabName) {
            const tabUmum = document.getElementById('tab-content-umum');
            const tabCabang = document.getElementById('tab-content-cabang');
            const btnUmum = document.getElementById('tab-btn-umum');
            const btnCabang = document.getElementById('tab-btn-cabang');

            if (tabName === 'umum') {
                tabUmum.classList.remove('hidden');
                tabCabang.classList.add('hidden');
                btnUmum.className = "text-xs font-extrabold px-4 py-2 bg-brand-600 text-white rounded-xl transition-all";
                btnCabang.className = "text-xs font-extrabold px-4 py-2 bg-slate-800 hover:bg-slate-700 text-slate-300 rounded-xl transition-all";
            } else {
                tabUmum.classList.add('hidden');
                tabCabang.classList.remove('hidden');
                btnUmum.className = "text-xs font-extrabold px-4 py-2 bg-slate-800 hover:bg-slate-700 text-slate-300 rounded-xl transition-all";
                btnCabang.className = "text-xs font-extrabold px-4 py-2 bg-brand-600 text-white rounded-xl transition-all";
                loadCabangToForm(); // pastikan data terisi pertama kali
            }
        }

        // Alur Autentikasi / Verifikasi PIN Owner
        function requestOwnerAuth() {
            document.getElementById('auth-modal').classList.remove('hidden');
            document.getElementById('auth-pin').value = '';
            document.getElementById('auth-pin').focus();
        }

        function closeOwnerAuth() {
            document.getElementById('auth-modal').classList.add('hidden');
        }

        function verifyOwnerPIN() {
            const enteredPin = document.getElementById('auth-pin').value;
            const correctPin = document.getElementById('owner-pin').value || '1234';

            if (enteredPin === correctPin) {
                closeOwnerAuth();
                toggleOwnerPanel(true);
                showToast("Akses Pemilik Terverifikasi! Membuka Panel.");
            } else {
                // PIN Salah
                const pinInput = document.getElementById('auth-pin');
                pinInput.classList.add('border-red-500', 'animate-shake');
                pinInput.value = '';
                setTimeout(() => pinInput.classList.remove('border-red-500', 'animate-shake'), 800);
            }
        }

        // Toggle visibility Owner Panel
        function toggleOwnerPanel(show) {
            const panel = document.getElementById('owner-panel');
            if (show) {
                panel.classList.remove('hidden');
            } else {
                panel.classList.add('hidden');
            }
        }

        // Simpan seluruh data Pengaturan Umum Owner
        function saveOwnerSettings() {
            const waNum = document.getElementById('owner-wa').value.trim();
            const gdriveLink = document.getElementById('owner-gdrive').value.trim();
            const mapsLink = document.getElementById('owner-maps').value.trim();

            // Update nomor di footer & tautan rute
            if (waNum) {
                document.getElementById('footer-wa-label').textContent = '+' + waNum.replace(/(\d{2})(\d{3})(\d{4})(\d{4})/, '$1 $2-$3-$4');
            }
            if (gdriveLink) {
                document.getElementById('gdrive-photo-link').href = gdriveLink;
            }
            if (mapsLink) {
                document.getElementById('btn-directions').href = mapsLink;
                // update default rute cabang 1
                cabangData[1].mapsLink = mapsLink;
            }

            // Ganti pratinjau foto utama jika tautan kustom diisi
            for (let i = 1; i <= 5; i++) {
                const urlVal = document.getElementById(`url-kamar-${i}`).value.trim();
                if (urlVal && !urlVal.startsWith('[Foto Lokal]')) {
                    const imgEl = document.getElementById(`img-kamar-${i}`);
                    if (imgEl) imgEl.src = urlVal;
                }
            }

            showToast("Seluruh Pengaturan Umum Berhasil Diaplikasikan!");
            toggleOwnerPanel(false);
        }

        // Preview local image upload
        function previewLocalImage(input, imgElementId) {
            if (input.files && input.files[0]) {
                const file = input.files[0];
                const localUrl = URL.createObjectURL(file);
                const targetImg = document.getElementById(imgElementId);
                if (targetImg) targetImg.src = localUrl;

                const photoNum = imgElementId.split('-').pop();
                const textInput = document.getElementById(`url-kamar-${photoNum}`);
                if (textInput) {
                    textInput.value = `[Foto Lokal]: ${file.name}`;
                    textInput.classList.add('text-green-400');
                }
            }
        }

        // Toggle mobile navigation menu
        const menuBtn = document.getElementById('mobile-menu-btn');
        const mobileMenu = document.getElementById('mobile-menu');
        menuBtn.addEventListener('click', () => {
            mobileMenu.classList.toggle('hidden');
        });

        // Setup dan Inisialisasi awal saat halaman termuat
        window.onload = function() {
            renderJaringanKost();
            switchLocation(1); // Set peta ke Rungkut Asri Timur secara default

            // Isi nilai awal kolom input foto pada Owner Panel
            for (let i = 1; i <= 5; i++) {
                const imgEl = document.getElementById(`img-kamar-${i}`);
                const inputEl = document.getElementById(`url-kamar-${i}`);
                if (imgEl && inputEl) {
                    inputEl.value = imgEl.src;
                }
            }

            // Hubungkan enter key pada modal PIN
            document.getElementById('auth-pin').addEventListener('keypress', function(e) {
                if (e.key === 'Enter') {
                    verifyOwnerPIN();
                }
            });
        }
    </script>
</body>
</html>
